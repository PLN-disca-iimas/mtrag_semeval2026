# ─────────────────────────────────────────────────────────────────────────────
# MT-RAG TASK A — Environment variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Voyage AI — required for Voyage-3-large dense retrieval
# Get your key at: https://dash.voyageai.com/api-keys
VOYAGE_API_KEY=your_voyage_api_key_here

# Cohere — required for query rewriting (Command-R) and Cohere reranking
# Get your key at: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_api_key_here

# Hugging Face — required for downloading some gated models
# Get your token at: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=your_hf_token_here

# ─────────────────────────────────────────────────────────────────────────────
# Optional: override default cache directories
# ─────────────────────────────────────────────────────────────────────────────
# HF_HOME=/path/to/your/hf/cache
# TRANSFORMERS_CACHE=/path/to/transformers/cache
